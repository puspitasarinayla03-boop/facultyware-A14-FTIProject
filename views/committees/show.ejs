<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">

<%- include('../partials/_sidebar', { user }) %>

<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="flex flex-1 items-center gap-2 text-sm text-muted-foreground">
      <a href="/committees" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
         class="hover:text-foreground transition-colors">Kepanitiaan</a>
      <span>/</span>
      <span class="text-foreground font-medium truncate max-w-[200px]"><%= committee.name %></span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
      <a href="/committees/<%= committee.id %>/edit"
         hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
         class="btn btn-sm gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
        </svg>
        Edit
      </a>
      <a href="/committees/<%= committee.id %>/sk" hx-boost="false" target="_blank" class="btn-outline btn-sm gap-1.5" style="color: black !important;" id="download-sk-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Cetak SK
      </a>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-8 bg-muted/20 min-h-[calc(100vh-3.5rem)]">
    <div class="max-w-screen-xl mx-auto space-y-6">

      <%# ── Hero Banner ── %>
      <%
        const statusColors = {
          draft:     'background:rgba(161,161,170,0.25); color:#e4e4e7; border-color:rgba(161,161,170,0.3);',
          active:    'background:rgba(52,211,153,0.25); color:#6ee7b7; border-color:rgba(52,211,153,0.35);',
          completed: 'background:rgba(96,165,250,0.25); color:#93c5fd; border-color:rgba(96,165,250,0.35);',
          cancelled: 'background:rgba(248,113,113,0.25); color:#fca5a5; border-color:rgba(248,113,113,0.35);',
        };
      %>
      <div class="shadow-sm overflow-hidden border border-border"
           style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1d4ed8 100%); border-radius: var(--radius-lg);">
        <div class="p-6 md:p-8" style="position:relative;">
          <div style="position:absolute;top:-20px;right:-20px;width:160px;height:160px;border-radius:9999px;background:rgba(255,255,255,0.04);pointer-events:none;"></div>
          <div style="position:absolute;top:20px;right:20px;width:80px;height:80px;border-radius:9999px;background:rgba(255,255,255,0.04);pointer-events:none;"></div>

          <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;margin-bottom:1rem;position:relative;z-index:1;">
            <span style="display:inline-flex;align-items:center;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;border:1px solid;<%= statusColors[committee.status] || statusColors.draft %>">
              ● <%= committee.status %>
            </span>
            <% if (internalMembers.length + externalMembers.length > 0) { %>
              <span style="display:inline-flex;align-items:center;gap:4px;padding:0.25rem 0.75rem;border-radius:9999px;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.85);border:1px solid rgba(255,255,255,0.18);">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                <%= internalMembers.length + externalMembers.length %> Anggota
              </span>
            <% } %>
          </div>

          <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:800;letter-spacing:-0.03em;color:#ffffff;line-height:1.2;margin-bottom:0.625rem;position:relative;z-index:1;max-width:700px;">
            <%= committee.name %>
          </h2>
          <% if (committee.event_id) { %>
            <a href="/projects/<%= committee.event_id %>" style="display:inline-flex;align-items:center;gap:0.375rem;font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.9);background:rgba(255,255,255,0.15);padding:0.25rem 0.75rem;border-radius:9999px;margin-bottom:0.75rem;position:relative;z-index:1;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.25)'" onmouseout="this.style.background='rgba(255,255,255,0.15)'">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/>
                <path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/><path d="M2 18h4"/>
                <path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/>
              </svg>
              Terkait Proyek: <%= committee.event_title %>
            </a>
          <% } %>
          <% if (committee.description) { %>
            <p style="font-size:0.9375rem;color:rgba(255,255,255,0.7);line-height:1.65;max-width:640px;position:relative;z-index:1;">
              <%= committee.description %>
            </p>
          <% } %>
        </div>
      </div>

      <%# ── Main Grid ── %>
      <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <%# Left: Details + Tujuan %>
        <div class="xl:col-span-2 space-y-6">

          <%# Detail Info %>
          <div class="card p-6">
            <h3 class="font-semibold text-sm text-muted-foreground uppercase tracking-wider mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              Jadwal & Status
            </h3>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Mulai</p>
                <p class="font-semibold text-sm">
                  <%= committee.start_date ? new Date(committee.start_date).toLocaleDateString('id-ID', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) : '-' %>
                </p>
              </div>
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Selesai</p>
                <p class="font-semibold text-sm">
                  <%= committee.end_date ? new Date(committee.end_date).toLocaleDateString('id-ID', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) : 'Belum ditentukan' %>
                </p>
              </div>
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Dibuat oleh</p>
                <p class="font-semibold text-sm"><%= committee.creator_name || 'Administrator' %></p>
              </div>
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Dibuat pada</p>
                <p class="font-semibold text-sm">
                  <%= committee.created_at ? new Date(committee.created_at).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) : '-' %>
                </p>
              </div>
            </div>
          </div>

          <%# Tujuan %>
          <div class="card p-6">
            <h3 class="font-semibold text-sm text-muted-foreground uppercase tracking-wider mb-3">Tujuan Kepanitiaan</h3>
            <p class="text-sm leading-relaxed"><%= committee.objective %></p>
          </div>

          <%# Anggota Eksternal %>
          <% if (externalMembers.length > 0) { %>
            <div class="card p-6">
              <h3 class="font-semibold text-sm text-muted-foreground uppercase tracking-wider mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500">
                  <circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/><path d="M19 3l2 2-6 6"/>
                </svg>
                Anggota Eksternal
              </h3>
              <div class="overflow-x-auto">
                <table class="table w-full text-sm">
                  <thead>
                    <tr>
                      <th class="text-center w-10">#</th>
                      <th>Nama</th>
                      <th>Institusi</th>
                      <th class="text-center">Jabatan</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% externalMembers.forEach((m, i) => { %>
                      <tr>
                        <td class="text-center text-muted-foreground"><%= i + 1 %></td>
                        <td class="font-medium"><%= m.name %></td>
                        <td class="text-muted-foreground"><%= m.institution || '-' %></td>
                        <td class="text-center"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-400"><%= m.role %></span></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>
        </div>

        <%# Right: Anggota Internal %>
        <div class="space-y-6">
          <div class="card p-6">
            <h3 class="font-semibold text-sm text-muted-foreground uppercase tracking-wider mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              Anggota Kepanitiaan
            </h3>
            <% if (internalMembers.length === 0) { %>
              <p class="text-sm text-muted-foreground text-center py-4">Belum ada anggota internal.</p>
            <% } else { %>
              <div class="space-y-3">
                <% internalMembers.forEach((m, i) => { %>
                  <div class="flex items-center gap-3">
                    <div class="flex aspect-square size-9 items-center justify-center rounded-full
                                <%= m.is_leader ? 'bg-primary text-primary-foreground' : 'bg-muted text-muted-foreground' %>
                                font-semibold text-sm shrink-0">
                      <%= m.name.charAt(0).toUpperCase() %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-sm truncate">
                        <%= m.name %>
                        <% if (m.is_leader) { %>
                          <span class="ml-1 text-xs text-primary font-bold">★</span>
                        <% } %>
                      </p>
                      <p class="text-xs text-muted-foreground"><%= m.role %></p>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <%# Quick Actions %>
          <div class="card p-6 space-y-3">
            <h3 class="font-semibold text-sm text-muted-foreground uppercase tracking-wider">Aksi Cepat</h3>
            <a href="/committees/<%= committee.id %>/sk" hx-boost="false" target="_blank" class="flex items-center gap-2.5 w-full px-3 py-2.5 rounded-md border hover:bg-accent hover:text-accent-foreground transition-colors text-sm font-medium" id="detail-sk-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/>
                <path d="M12 18v-6"/><path d="M9 15l3 3 3-3"/>
              </svg>
              Download SK (.docx)
            </a>
            <a href="/committees/<%= committee.id %>/edit"
               hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
               class="flex items-center gap-2.5 w-full px-3 py-2.5 rounded-md border hover:bg-accent hover:text-accent-foreground transition-colors text-sm font-medium" id="detail-edit-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
              </svg>
              Edit Kepanitiaan
            </a>
            <form method="POST" action="/committees/<%= committee.id %>/delete">
              <button type="button" onclick="showDeleteModal(this.closest('form'))"
                      class="flex items-center gap-2.5 w-full px-3 py-2.5 rounded-md border border-destructive/30 text-destructive hover:bg-destructive/10 transition-colors text-sm font-medium" id="detail-delete-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
                  <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                </svg>
                Hapus Kepanitiaan
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../partials/_scripts') %>
</body>
</html>
