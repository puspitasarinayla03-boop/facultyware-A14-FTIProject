<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">

<%- include('../partials/_sidebar', { user }) %>

<main id="content">

  <%# ── Page Header ─────────────────────────────────────────────────────────── %>
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="flex flex-1 items-center gap-4">
      <h1 class="text-base font-semibold">Kelola Kepanitiaan</h1>
      <span class="text-muted-foreground text-sm hidden sm:inline">(<%= pagination.total %> kepanitiaan)</span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
      <a href="/committees/create"
         hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
         class="btn btn-sm gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14"/><path d="M5 12h14"/>
        </svg>
        Buat Kepanitiaan
      </a>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-8 bg-muted/20 min-h-[calc(100vh-3.5rem)]">
    <div class="max-w-screen-xl mx-auto space-y-6">

      <%# ── Filter Bar ─────────────────────────────────────────────────────────── %>
      <div class="card p-4">
        <form method="GET" action="/committees" class="flex flex-wrap gap-3 items-end">
          <div class="relative flex-1 min-w-[200px] max-w-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="absolute left-2.5 top-1/2 -translate-y-1/2 text-muted-foreground pointer-events-none">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input type="text" name="search" value="<%= filters.search %>"
                   placeholder="Cari kepanitiaan..." class="input pl-8 h-9 text-sm w-full" id="committee-search-input">
          </div>

          <div class="w-40">
            <select name="status" class="select w-full" id="committee-status-filter">
              <option value="">Semua Status</option>
              <% const statusOpts = { draft:'Draft', active:'Aktif', completed:'Selesai', cancelled:'Dibatalkan' }; %>
              <% Object.entries(statusOpts).forEach(([val, label]) => { %>
                <option value="<%= val %>" <%= filters.status === val ? 'selected' : '' %>><%= label %></option>
              <% }) %>
            </select>
          </div>

          <button type="submit" class="btn btn-sm" id="committee-filter-btn">Filter</button>
          <% if (filters.search || filters.status) { %>
            <a href="/committees" class="btn-outline btn-sm" id="committee-reset-filter">Reset</a>
          <% } %>
        </form>
      </div>

      <%# ── Table ──────────────────────────────────────────────────────────────── %>
      <div class="card overflow-hidden p-0">
        <% if (committees.length === 0) { %>
          <div class="flex flex-col items-center justify-center py-20 gap-4 text-center">
            <div class="p-5 rounded-full bg-muted">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">Belum Ada Kepanitiaan</p>
              <p class="text-sm text-muted-foreground">Klik tombol "Buat Kepanitiaan" untuk memulai.</p>
            </div>
            <a href="/committees/create" class="btn btn-sm">+ Buat Kepanitiaan Pertama</a>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="table w-full text-sm">
              <thead>
                <tr>
                  <th class="text-center w-12">#</th>
                  <th>Nama Kepanitiaan</th>
                  <th class="text-center">Status</th>
                  <th class="text-center hidden md:table-cell">Anggota</th>
                  <th class="text-center hidden lg:table-cell">Mulai</th>
                  <th class="text-center hidden lg:table-cell">Selesai</th>
                  <th class="text-center">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% committees.forEach((c, i) => {
                  const statusClass = {
                    draft:     'bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300',
                    active:    'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-400',
                    completed: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-400',
                    cancelled: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-400',
                  }[c.status] || '';
                  const statusLabel = { draft:'Draft', active:'Aktif', completed:'Selesai', cancelled:'Dibatalkan' }[c.status] || c.status;
                  const startFmt = c.start_date ? new Date(c.start_date).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) : '-';
                  const endFmt   = c.end_date   ? new Date(c.end_date).toLocaleDateString('id-ID',   { day:'2-digit', month:'short', year:'numeric' }) : '-';
                %>
                <tr>
                  <td class="text-center text-muted-foreground">
                    <%= (pagination.page - 1) * pagination.limit + i + 1 %>
                  </td>
                  <td>
                    <a href="/committees/<%= c.id %>" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
                       class="font-semibold text-foreground hover:text-primary transition-colors block"><%= c.name %></a>
                    <p class="text-xs text-muted-foreground mt-0.5">oleh <%= c.creator_name || 'Admin' %></p>
                  </td>
                  <td class="text-center">
                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= statusClass %>">
                      <%= statusLabel %>
                    </span>
                  </td>
                  <td class="text-center hidden md:table-cell">
                    <span class="font-medium"><%= c.member_count %> orang</span>
                  </td>
                  <td class="text-center hidden lg:table-cell text-sm text-muted-foreground"><%= startFmt %></td>
                  <td class="text-center hidden lg:table-cell text-sm text-muted-foreground"><%= endFmt %></td>
                  <td class="text-center">
                    <div class="flex items-center justify-center gap-1">
                      <a href="/committees/<%= c.id %>"
                         hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
                         class="btn-sm-icon-ghost size-7" title="Lihat Detail">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                      </a>
                      <a href="/committees/<%= c.id %>/sk" target="_blank"
                         class="btn-sm-icon-ghost size-7 text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50 dark:text-emerald-400 dark:hover:bg-emerald-900/30" title="Download SK">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>
                        </svg>
                      </a>
                      <a href="/committees/<%= c.id %>/edit"
                         hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
                         class="btn-sm-icon-ghost size-7 text-blue-600 hover:text-blue-700 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/30" title="Edit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
                        </svg>
                      </a>
                      <form method="POST" action="/committees/<%= c.id %>/delete" class="inline-block m-0">
                        <button type="button" onclick="showDeleteModal(this.closest('form'))"
                                class="btn-sm-icon-ghost size-7 text-destructive hover:bg-destructive/10" title="Hapus">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
                            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <%# Pagination %>
          <% if (pagination.totalPages > 1) { %>
            <div class="flex items-center justify-between px-4 py-3 border-t">
              <p class="text-sm text-muted-foreground">
                Halaman <%= pagination.page %> dari <%= pagination.totalPages %>
              </p>
              <div class="flex gap-1">
                <% if (pagination.page > 1) { %>
                  <a href="?page=<%= pagination.page - 1 %>&search=<%= filters.search %>&status=<%= filters.status %>"
                     class="btn-sm-outline px-3">‹ Sebelumnya</a>
                <% } %>
                <% if (pagination.page < pagination.totalPages) { %>
                  <a href="?page=<%= pagination.page + 1 %>&search=<%= filters.search %>&status=<%= filters.status %>"
                     class="btn-sm-outline px-3">Berikutnya ›</a>
                <% } %>
              </div>
            </div>
          <% } %>
        <% } %>
      </div>

    </div>
  </div>


  <%# ── Delete Confirmation Modal (Basecoat dialog) ── %>
  <dialog id="delete-modal" class="dialog">
    <div class="dialog-content max-w-sm">
      <header class="dialog-header">
        <h2 class="dialog-title">Hapus Kepanitiaan?</h2>
        <p class="dialog-description">Tindakan ini tidak dapat dibatalkan. Data kepanitiaan akan dihapus permanen.</p>
      </header>
      <footer class="dialog-footer">
        <button type="button" class="btn-outline" onclick="document.getElementById('delete-modal').close()">Batal</button>
        <button type="button" id="confirm-delete-btn" class="btn bg-destructive text-white hover:bg-destructive/90">Hapus</button>
      </footer>
    </div>
  </dialog>

  <script>
    let _deleteForm = null;
    function showDeleteModal(form) {
      _deleteForm = form;
      document.getElementById('delete-modal').showModal();
    }
    document.getElementById('confirm-delete-btn').addEventListener('click', () => {
      if (_deleteForm) _deleteForm.submit();
    });
  </script>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>
