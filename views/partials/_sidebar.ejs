<%# Sidebar navigation — FTI Module %>
<script>
  (() => {
    document.addEventListener("DOMContentLoaded", () => {
      const sidebar = document.getElementById("sidebar");
      if (!sidebar) return;
      const updateCurrentLinks = () => {
        const currentPath = window.location.pathname.replace(/\/$/, "");
        sidebar.querySelectorAll("a").forEach((a) => {
          const href = a.getAttribute("href");
          if (!href) return;
          try {
            const url = new URL(href, window.location.origin);
            const itemPath = url.pathname.replace(/\/$/, "");
            if (itemPath === currentPath) {
              a.setAttribute("aria-current", "page");
            } else {
              a.removeAttribute("aria-current");
            }
          } catch (_) {}
        });
      };
      document.addEventListener("htmx:afterSettle", updateCurrentLinks);
      window.addEventListener("popstate", updateCurrentLinks);
      updateCurrentLinks();
    });
  })();
</script>

<aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
  <nav aria-label="Sidebar navigation">

    <%# ── Branding ─────────────────────────────────────────────────────────── %>
    <header>
      <a href="/projects"
         hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
         class="btn-ghost p-2 h-14 w-full justify-start gap-3">
        <div class="bg-primary text-primary-foreground flex aspect-square size-9 items-center justify-center rounded-lg shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <div class="grid flex-1 text-left leading-tight">
          <span class="truncate font-semibold text-sm">FacultyWare</span>
          <span class="truncate text-xs text-muted-foreground">FTI Module</span>
        </div>
      </a>
    </header>

    <%# ── Navigation ──────────────────────────────────────────────────────── %>
    <section class="scrollbar flex flex-col gap-4 overflow-x-hidden overflow-y-auto py-4 px-2">

      <div role="group" aria-labelledby="nav-project-mgmt">
        <h3 id="nav-project-mgmt" class="text-xs font-medium text-muted-foreground uppercase tracking-wider px-2 mb-1">
          Project Management
        </h3>
        <ul class="flex flex-col gap-0.5">

          <li>
            <a href="/projects"
               hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
               class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors [&[aria-current='page']]:bg-accent [&[aria-current='page']]:text-accent-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                <path d="M3 3h6v6H3z"/><path d="M15 3h6v6h-6z"/><path d="M3 15h6v6H3z"/>
                <path d="M15 18h6"/><path d="M18 15v6"/>
              </svg>
              <span>Semua Proyek</span>
            </a>
          </li>

          <li>
            <a href="/projects/create"
               hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
               class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors [&[aria-current='page']]:bg-accent [&[aria-current='page']]:text-accent-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v8"/><path d="M8 12h8"/>
              </svg>
              <span>Buat Proyek Baru</span>
            </a>
          </li>

        </ul>
      </div>

    </section>

    <%# ── User / Logout Footer ────────────────────────────────────────────── %>
    <footer class="border-t px-2 py-2">
      <div id="user-popover" class="popover w-full">
        <button id="user-popover-trigger" type="button"
                aria-expanded="false" aria-controls="user-popover-content"
                data-keep-mobile-sidebar-open=""
                class="btn-ghost p-2 h-12 w-full flex items-center gap-2.5 justify-start">
          <div class="flex aspect-square size-8 items-center justify-center rounded-lg bg-primary text-primary-foreground font-semibold text-sm shrink-0">
            <%= user ? user.charAt(0).toUpperCase() : 'A' %>
          </div>
          <div class="grid flex-1 text-left text-sm leading-tight">
            <span class="truncate font-medium"><%= user || 'Admin' %></span>
            <span class="truncate text-xs text-muted-foreground">Administrator</span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/>
          </svg>
        </button>

        <div id="user-popover-content" data-popover aria-hidden="true" data-side="top"
             class="w-[220px] p-1">
          <div class="px-2 py-1.5 border-b mb-1">
            <p class="text-sm font-semibold"><%= user || 'Admin' %></p>
            <p class="text-xs text-muted-foreground">FTI Administrator</p>
          </div>
          <a href="/logout"
             class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm text-destructive hover:bg-destructive/10 transition-colors cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            <span>Logout</span>
          </a>
        </div>
      </div>
    </footer>

  </nav>
</aside>
