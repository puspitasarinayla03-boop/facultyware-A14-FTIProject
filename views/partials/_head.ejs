<head>
  <%# Theme initialization (harus paling awal agar tidak ada flash) %>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        const prefersDark = matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored ? stored === "dark" : prefersDark) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      document.addEventListener("basecoat:theme", (e) => {
        const mode = e.detail?.mode;
        const isDark = mode === "dark" ? true : mode === "light" ? false
          : !document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("dark", isDark);
        try { localStorage.setItem("themeMode", isDark ? "dark" : "light"); } catch (_) {}
      });
    })();
  </script>

  <meta charset="utf-8" />
  <meta http-equiv="Content-Language" content="en" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> — FacultyWare FTI</title>
  <meta name="description" content="FacultyWare FTI — Sistem Manajemen Proyek Fakultas Teknologi Informasi" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />

  <link rel="stylesheet" href="/assets/styles.css" />

  <script src="/assets/js/basecoat.js"      defer></script>
  <script src="/assets/js/dropdown-menu.js" defer></script>
  <script src="/assets/js/popover.js"       defer></script>
  <script src="/assets/js/sidebar.js"       defer></script>
  <script src="/assets/js/toast.js"         defer></script>
  <script src="/assets/js/select.js"        defer></script>
  <script src="/assets/htmx.org@2.0.4"     defer></script>

  <script>
    document.addEventListener("htmx:historyRestore", () => {
      if (window.basecoat) window.basecoat.initAll();
    });
  </script>
</head>
