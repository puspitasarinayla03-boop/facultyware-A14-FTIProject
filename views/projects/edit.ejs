<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased">

<%- include('../partials/_sidebar', { user }) %>

<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/projects/<%= project.id %>"
       hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
       class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Kembali
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold">Edit Proyek</h1>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </button>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-md mx-auto">

      <% if (errors && errors.length > 0) { %>
      <div class="mb-6 rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive">
        <p class="font-medium mb-1">Terdapat kesalahan pada input:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form method="POST" action="/projects/<%= project.id %>/update" class="grid gap-6">

        <div class="card">
          <header>
            <h2>Informasi Proyek / Kegiatan</h2>
            <p>Ubah detail utama tentang proyek atau kegiatan.</p>
          </header>
          <section class="grid gap-5">
            <div class="grid gap-2">
              <label for="name">Nama Kegiatan <span class="text-destructive">*</span></label>
              <input type="text" id="name" name="name" class="input w-full"
                     value="<%= project.name || '' %>"
                     placeholder="Masukkan nama proyek atau kegiatan..." required maxlength="255" />
            </div>

            <div class="grid gap-2">
              <label for="description">Deskripsi</label>
              <textarea id="description" name="description" class="input w-full min-h-[100px] py-2"
                        placeholder="Deskripsi singkat tentang proyek..."><%= project.description || '' %></textarea>
            </div>

            <div class="grid gap-2">
              <label for="objective">Tujuan Kegiatan <span class="text-destructive">*</span></label>
              <textarea id="objective" name="objective" class="input w-full min-h-[80px] py-2"
                        placeholder="Apa yang ingin dicapai dari kegiatan ini?" required><%= project.objective || '' %></textarea>
            </div>
          </section>
        </div>

        <div class="card">
          <header>
            <h2>Jadwal Pelaksanaan</h2>
          </header>
          <section class="grid gap-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="start_date">Tanggal Mulai <span class="text-destructive">*</span></label>
                <input type="date" id="start_date" name="start_date" class="input w-full"
                       value="<%= project.start_date ? new Date(project.start_date).toISOString().split('T')[0] : '' %>" required />
              </div>
              <div class="grid gap-2">
                <label for="end_date">Tanggal Selesai</label>
                <input type="date" id="end_date" name="end_date" class="input w-full"
                       value="<%= project.end_date ? new Date(project.end_date).toISOString().split('T')[0] : '' %>" />
              </div>
            </div>
          </section>
        </div>

        <div class="card">
          <header>
            <h2>Status</h2>
          </header>
          <section>
            <div class="grid gap-2">
              <label for="status">Status Kegiatan <span class="text-destructive">*</span></label>
              <select id="status" name="status" class="select w-full" required>
                <option value="">Pilih status...</option>
                <option value="draft"     <%= project.status === 'draft'     ? 'selected' : '' %>>Draft</option>
                <option value="active"    <%= project.status === 'active'    ? 'selected' : '' %>>Aktif</option>
                <option value="completed" <%= project.status === 'completed' ? 'selected' : '' %>>Selesai</option>
                <option value="cancelled" <%= project.status === 'cancelled' ? 'selected' : '' %>>Dibatalkan</option>
              </select>
            </div>
          </section>
        </div>

        <div class="flex items-center justify-end gap-3 pt-2">
          <a href="/projects/<%= project.id %>"
             hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
             class="btn-outline">Batal</a>
          <button type="submit" class="btn">Simpan Perubahan</button>
        </div>

      </form>
    </div>
  </div>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>
