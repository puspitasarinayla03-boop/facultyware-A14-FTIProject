<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased">

<%- include('../partials/_sidebar', { user }) %>

<main id="content">

  <%# ── Page Header ─────────────────────────────────────────────────────────── %>
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/projects"
       hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
       class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Kembali
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold">Buat Proyek Baru</h1>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
    </div>
  </header>

  <%# ── Form ────────────────────────────────────────────────────────────────── %>
  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-md mx-auto">

      <%# Error Alert %>
      <% if (errors && errors.length > 0) { %>
      <div class="mb-6 rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive">
        <p class="font-medium mb-1">Terdapat kesalahan pada input:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form method="POST" action="/projects" class="grid gap-6">

        <%# ── Informasi Dasar ─────────────────────────────────────────────────── %>
        <div class="card">
          <header>
            <h2>Informasi Dasar</h2>
            <p>Detail utama tentang proyek atau kegiatan yang akan dilaksanakan.</p>
          </header>

          <section class="grid gap-6">
            <div class="grid gap-2">
              <label for="title">Judul Proyek <span class="text-destructive">*</span></label>
              <input type="text" id="title" name="title" class="input w-full"
                     value="<%= old.title || '' %>"
                     placeholder="Masukkan judul proyek..." required maxlength="255" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="event_type">Tipe Kegiatan <span class="text-destructive">*</span></label>
                <select id="event_type" name="event_type" class="select w-full" required>
                  <option value="">Pilih tipe...</option>
                  <option value="seminar"    <%= old.event_type === 'seminar'    ? 'selected' : '' %>>Seminar</option>
                  <option value="workshop"   <%= old.event_type === 'workshop'   ? 'selected' : '' %>>Workshop</option>
                  <option value="training"   <%= old.event_type === 'training'   ? 'selected' : '' %>>Training</option>
                  <option value="conference" <%= old.event_type === 'conference' ? 'selected' : '' %>>Conference</option>
                  <option value="webinar"    <%= old.event_type === 'webinar'    ? 'selected' : '' %>>Webinar</option>
                  <option value="other"      <%= old.event_type === 'other'      ? 'selected' : '' %>>Lainnya</option>
                </select>
              </div>

              <div class="grid gap-2">
                <label for="delivery_mode">Mode Pelaksanaan <span class="text-destructive">*</span></label>
                <select id="delivery_mode" name="delivery_mode" class="select w-full" required>
                  <option value="">Pilih mode...</option>
                  <option value="offline" <%= old.delivery_mode === 'offline' ? 'selected' : '' %>>Offline</option>
                  <option value="online"  <%= old.delivery_mode === 'online'  ? 'selected' : '' %>>Online</option>
                  <option value="hybrid"  <%= old.delivery_mode === 'hybrid'  ? 'selected' : '' %>>Hybrid</option>
                </select>
              </div>
            </div>

            <div class="grid gap-2">
              <label for="description">Deskripsi</label>
              <textarea id="description" name="description" class="input w-full min-h-[100px] py-2"
                        placeholder="Deskripsi singkat tentang proyek..."><%= old.description || '' %></textarea>
            </div>

            <div class="grid gap-2">
              <label for="objectives">Tujuan Kegiatan</label>
              <textarea id="objectives" name="objectives" class="input w-full min-h-[80px] py-2"
                        placeholder="Apa yang ingin dicapai dari kegiatan ini?"><%= old.objectives || '' %></textarea>
            </div>
          </section>
        </div>

        <%# ── Jadwal & Tempat ────────────────────────────────────────────────── %>
        <div class="card">
          <header>
            <h2>Jadwal & Lokasi</h2>
          </header>

          <section class="grid gap-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="start_date">Tanggal Mulai <span class="text-destructive">*</span></label>
                <input type="date" id="start_date" name="start_date" class="input w-full"
                       value="<%= old.start_date || '' %>" required />
              </div>
              <div class="grid gap-2">
                <label for="end_date">Tanggal Selesai <span class="text-destructive">*</span></label>
                <input type="date" id="end_date" name="end_date" class="input w-full"
                       value="<%= old.end_date || '' %>" required />
              </div>
              <div class="grid gap-2">
                <label for="start_time">Jam Mulai</label>
                <input type="time" id="start_time" name="start_time" class="input w-full"
                       value="<%= old.start_time || '' %>" />
              </div>
              <div class="grid gap-2">
                <label for="end_time">Jam Selesai</label>
                <input type="time" id="end_time" name="end_time" class="input w-full"
                       value="<%= old.end_time || '' %>" />
              </div>
            </div>

            <div class="grid gap-2 mt-2">
              <label for="venue">Lokasi / Venue (Offline)</label>
              <input type="text" id="venue" name="venue" class="input w-full"
                     value="<%= old.venue || '' %>" placeholder="Gedung, ruangan, atau alamat..." />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="online_platform">Platform Online</label>
                <input type="text" id="online_platform" name="online_platform" class="input w-full"
                       value="<%= old.online_platform || '' %>" placeholder="Zoom, Google Meet, dll..." />
              </div>
              <div class="grid gap-2">
                <label for="online_link">Link Online</label>
                <input type="url" id="online_link" name="online_link" class="input w-full"
                       value="<%= old.online_link || '' %>" placeholder="https://..." />
              </div>
            </div>
          </section>
        </div>

        <%# ── Peserta & Status ───────────────────────────────────────────────── %>
        <div class="card">
          <header>
            <h2>Peserta & Pengaturan</h2>
          </header>

          <section class="grid gap-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="quota">Kuota Peserta</label>
                <input type="number" id="quota" name="quota" min="1" class="input w-full"
                       value="<%= old.quota || '' %>" placeholder="Kosongkan jika tidak terbatas" />
              </div>
              <div class="grid gap-2">
                <label for="registration_deadline">Deadline Pendaftaran</label>
                <input type="datetime-local" id="registration_deadline" name="registration_deadline"
                       class="input w-full" value="<%= old.registration_deadline || '' %>" />
              </div>
            </div>

            <div class="grid gap-2 mt-2">
              <label for="status">Status <span class="text-destructive">*</span></label>
              <select id="status" name="status" class="select w-full" required>
                <option value="">Pilih status...</option>
                <option value="draft"     <%= (old.status || 'draft') === 'draft'     ? 'selected' : '' %>>Draft</option>
                <option value="published" <%= old.status === 'published' ? 'selected' : '' %>>Published</option>
                <option value="closed"    <%= old.status === 'closed'    ? 'selected' : '' %>>Closed</option>
                <option value="cancelled" <%= old.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </div>
          </section>
        </div>

        <%# ── Actions ────────────────────────────────────────────────────────── %>
        <div class="flex items-center justify-end gap-3 pt-2">
          <a href="/projects"
             hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
             class="btn-outline">Batal</a>
          <button type="submit" class="btn">Simpan Proyek</button>
        </div>

      </form>
    </div>
  </div>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>
