<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">

<%- include('../partials/_sidebar', { user }) %>

<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/projects"
       hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
       class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Semua Proyek
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold truncate flex-1 md:max-w-xs"><%= project.name %></h1>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>

      <a href="/projects/<%= project.id %>/edit"
         hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
         class="btn btn-sm gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
        </svg>
        Edit
      </a>

      <% if (memberCount === 0) { %>
      <form method="POST" action="/projects/<%= project.id %>/delete">
        <button type="button" onclick="showDeleteModal(this.closest('form'))"
                class="btn-outline btn-sm text-destructive hover:bg-destructive/10 hover:border-destructive/40 gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
          Hapus
        </button>
      </form>
      <% } %>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-10 bg-muted/20 min-h-[calc(100vh-3.5rem)]">
    <div class="max-w-screen-xl mx-auto space-y-6">

      <%# ── Error message from delete attempt ── %>
      <% if (typeof query !== 'undefined' && query && query.error === 'has_members') { %>
      <div class="rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive">
        Proyek ini tidak dapat dihapus karena sudah memiliki anggota kepanitiaan. Hapus anggotanya terlebih dahulu.
      </div>
      <% } %>

      <%# ── Hero Banner ── %>
      <%
        const statusColors = {
          draft:     'background:rgba(161,161,170,0.25); color:#e4e4e7; border-color:rgba(161,161,170,0.3);',
          active:    'background:rgba(52,211,153,0.25); color:#6ee7b7; border-color:rgba(52,211,153,0.35);',
          completed: 'background:rgba(96,165,250,0.25); color:#93c5fd; border-color:rgba(96,165,250,0.35);',
          cancelled: 'background:rgba(248,113,113,0.25); color:#fca5a5; border-color:rgba(248,113,113,0.35);',
        };
        const statusLabels = { draft: 'Draft', active: 'Aktif', completed: 'Selesai', cancelled: 'Dibatalkan' };
      %>
      <div class="shadow-sm overflow-hidden border border-border" style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1d4ed8 100%); border-radius: var(--radius-lg);">
        <div class="p-6 md:p-8" style="position: relative;">
          <div style="position:absolute; top:-20px; right:-20px; width:160px; height:160px; border-radius:9999px; background: rgba(255,255,255,0.04); pointer-events:none;"></div>
          <div style="position:absolute; top:20px; right:20px; width:80px; height:80px; border-radius:9999px; background: rgba(255,255,255,0.04); pointer-events:none;"></div>

          <div style="display:flex; flex-wrap:wrap; align-items:center; gap:0.5rem; margin-bottom:1.25rem; position:relative; z-index:1;">
            <span style="display:inline-flex; align-items:center; padding: 0.25rem 0.75rem; border-radius:9999px; font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; border:1px solid; <%= statusColors[project.status] || statusColors.draft %>">
              <%= statusLabels[project.status] || project.status %>
            </span>
            <% if (memberCount > 0) { %>
            <span style="display:inline-flex; align-items:center; padding: 0.25rem 0.75rem; border-radius:9999px; font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.85); border:1px solid rgba(255,255,255,0.18);">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <%= memberCount %> Anggota
            </span>
            <% } %>
          </div>

          <h2 style="font-size:1.5rem; font-weight:700; color:#fff; margin-bottom:0.5rem; position:relative; z-index:1;"><%= project.name %></h2>
          <% if (project.description) { %>
          <p style="color:rgba(255,255,255,0.7); font-size:0.875rem; max-width:600px; position:relative; z-index:1;"><%= project.description %></p>
          <% } %>

          <div style="display:flex; flex-wrap:wrap; gap:1.5rem; margin-top:1.5rem; position:relative; z-index:1;">
            <% if (project.start_date) { %>
            <div>
              <p style="font-size:0.7rem; color:rgba(255,255,255,0.5); font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:0.25rem;">Tanggal Mulai</p>
              <p style="font-size:0.875rem; color:rgba(255,255,255,0.9); font-weight:500;"><%= new Date(project.start_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
            </div>
            <% } %>
            <% if (project.end_date) { %>
            <div>
              <p style="font-size:0.7rem; color:rgba(255,255,255,0.5); font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:0.25rem;">Tanggal Selesai</p>
              <p style="font-size:0.875rem; color:rgba(255,255,255,0.9); font-weight:500;"><%= new Date(project.end_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
            </div>
            <% } %>
            <% if (project.creator_name) { %>
            <div>
              <p style="font-size:0.7rem; color:rgba(255,255,255,0.5); font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:0.25rem;">Dibuat Oleh</p>
              <p style="font-size:0.875rem; color:rgba(255,255,255,0.9); font-weight:500;"><%= project.creator_name %></p>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <%# ── Detail Cards ── %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% if (project.objective) { %>
        <div class="card">
          <header>
            <h3 class="font-semibold">Tujuan Kegiatan</h3>
          </header>
          <section>
            <p class="text-sm text-muted-foreground leading-relaxed"><%= project.objective %></p>
          </section>
        </div>
        <% } %>

        <% if (project.expected_outcome) { %>
        <div class="card">
          <header>
            <h3 class="font-semibold">Hasil yang Diharapkan (Outcome)</h3>
          </header>
          <section>
            <p class="text-sm text-muted-foreground leading-relaxed"><%= project.expected_outcome %></p>
          </section>
        </div>
        <% } %>

        <div class="card">
          <header>
            <h3 class="font-semibold">Informasi Teknis</h3>
          </header>
          <section class="space-y-3">
            <div class="flex justify-between items-center text-sm">
              <span class="text-muted-foreground">ID Proyek</span>
              <span class="font-mono font-medium">#<%= project.id %></span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-muted-foreground">Status</span>
              <span class="font-medium"><%= statusLabels[project.status] || project.status %></span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-muted-foreground">Jumlah Panitia</span>
              <span class="font-medium"><%= memberCount %> orang</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-muted-foreground">Dibuat</span>
              <span><%= project.created_at ? new Date(project.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : '-' %></span>
            </div>
          </section>
        </div>
      </div>

      <%# ── Link to Committee ── %>
      <% if (memberCount > 0) { %>
      <div class="card">
        <section class="flex items-center justify-between gap-4">
          <div>
            <p class="font-medium">Kelola Kepanitiaan</p>
            <p class="text-sm text-muted-foreground">Proyek ini sudah memiliki <%= memberCount %> anggota kepanitiaan.</p>
          </div>
          <a href="/committees/<%= project.id %>"
             hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
             class="btn btn-sm shrink-0">Lihat Kepanitiaan</a>
        </section>
      </div>
      <% } else { %>
      <div class="card">
        <section class="flex items-center justify-between gap-4">
          <div>
            <p class="font-medium">Kepanitiaan Belum Dibuat</p>
            <p class="text-sm text-muted-foreground">Tambahkan susunan anggota kepanitiaan untuk proyek ini.</p>
          </div>
          <a href="/committees/<%= project.id %>/edit"
             hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
             class="btn btn-sm shrink-0">Tambah Anggota</a>
        </section>
      </div>
      <% } %>

    </div>
  </div>

  <%# ── Delete Confirmation Modal ── %>
  <dialog id="delete-modal" class="dialog">
    <div class="dialog-content max-w-sm">
      <header class="dialog-header">
        <h2 class="dialog-title">Hapus Proyek?</h2>
        <p class="dialog-description">Tindakan ini tidak dapat dibatalkan. Data proyek akan dihapus permanen.</p>
      </header>
      <footer class="dialog-footer">
        <button type="button" class="btn-outline" onclick="document.getElementById('delete-modal').close()">Batal</button>
        <button type="button" id="confirm-delete-btn" class="btn bg-destructive text-white hover:bg-destructive/90">Hapus</button>
      </footer>
    </div>
  </dialog>

  <script>
    var _deleteForm = null;
    function showDeleteModal(form) {
      _deleteForm = form;
      document.getElementById('delete-modal').showModal();
    }
    document.getElementById('confirm-delete-btn').addEventListener('click', () => {
      if (_deleteForm) _deleteForm.submit();
    });
  </script>
</main>

<%- include('../partials/_scripts') %>
</body>
</html>
