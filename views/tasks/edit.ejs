<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">
<%- include('../partials/_sidebar', { user }) %>
<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="flex flex-1 items-center gap-2 text-sm text-muted-foreground">
      <a href="/committees/<%= committee.id %>/tasks" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="hover:text-foreground transition-colors">Task</a>
      <span>/</span>
      <span class="text-foreground font-medium truncate">Edit: <%= task.title %></span>
    </div>
    <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center ml-auto">
      <span class="hidden dark:block"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></span>
      <span class="block dark:hidden"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg></span>
    </button>
  </header>

  <div class="p-4 md:p-6 xl:p-8 bg-muted/20 min-h-[calc(100vh-3.5rem)]">
    <div class="max-w-2xl mx-auto">

      <div class="mb-6">
        <h2 class="text-xl font-bold tracking-tight">Edit Task</h2>
        <p class="text-sm text-muted-foreground mt-1">Kepanitiaan: <strong><%= committee.name %></strong></p>
      </div>

      <% if (errors && errors.length > 0) { %>
      <div class="rounded-lg border border-destructive/40 bg-destructive/10 text-destructive px-4 py-3 mb-6">
        <p class="font-semibold text-sm mb-1">Terdapat kesalahan:</p>
        <ul class="text-sm list-disc list-inside space-y-0.5">
          <% errors.forEach(e => { %><li><%= e %></li><% }) %>
        </ul>
      </div>
      <% } %>

      <form method="POST" action="/committees/<%= committee.id %>/tasks/<%= task.id %>/update" class="grid gap-5">

        <div class="card p-6 grid gap-4">
          <h3 class="font-semibold text-base">Detail Task</h3>

          <div class="grid gap-2">
            <label class="label" for="title">Judul Task <span class="text-destructive">*</span></label>
            <input type="text" id="title" name="title" class="input w-full"
                   value="<%= task.title || '' %>" placeholder="Judul task..." required maxlength="255" />
          </div>

          <div class="grid gap-2">
            <label class="label" for="description">Deskripsi</label>
            <textarea id="description" name="description" class="textarea w-full min-h-[80px]"
                      placeholder="Detail pekerjaan..."><%= task.description || '' %></textarea>
          </div>

          <div class="grid gap-2">
            <label class="label" for="committee_member_id">Anggota Bertanggung Jawab <span class="text-destructive">*</span></label>
            <select id="committee_member_id" name="committee_member_id" class="select w-full" required>
              <option value="">-- Pilih Anggota --</option>
              <% members.forEach(m => { %>
                <option value="<%= m.id %>" <%= task.committee_member_id == m.id ? 'selected' : '' %>>
                  <%= m.name %> — <%= m.role %><%= m.type === 'external' ? ' (Eksternal)' : '' %>
                </option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="card p-6 grid gap-4">
          <h3 class="font-semibold text-base">Status & Prioritas</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="grid gap-2">
              <label class="label" for="status">Status <span class="text-destructive">*</span></label>
              <select id="status" name="status" class="select w-full" required>
                <option value="todo"        <%= task.status === 'todo'        ? 'selected' : '' %>>To Do</option>
                <option value="in_progress" <%= task.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                <option value="done"        <%= task.status === 'done'        ? 'selected' : '' %>>Done</option>
                <option value="blocked"     <%= task.status === 'blocked'     ? 'selected' : '' %>>Blocked</option>
              </select>
            </div>
            <div class="grid gap-2">
              <label class="label" for="priority">Prioritas <span class="text-destructive">*</span></label>
              <select id="priority" name="priority" class="select w-full" required>
                <option value="low"    <%= task.priority === 'low'    ? 'selected' : '' %>>Rendah</option>
                <option value="medium" <%= task.priority === 'medium' ? 'selected' : '' %>>Sedang</option>
                <option value="high"   <%= task.priority === 'high'   ? 'selected' : '' %>>Tinggi</option>
              </select>
            </div>
          </div>
        </div>

        <div class="card p-6 grid gap-4">
          <h3 class="font-semibold text-base">Jadwal</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="grid gap-2">
              <label class="label" for="start_date">Tanggal Mulai</label>
              <input type="date" id="start_date" name="start_date" class="input w-full"
                     value="<%= task.start_date ? new Date(task.start_date).toISOString().split('T')[0] : '' %>" />
            </div>
            <div class="grid gap-2">
              <label class="label" for="due_date">Tenggat Waktu</label>
              <input type="date" id="due_date" name="due_date" class="input w-full"
                     value="<%= task.due_date ? new Date(task.due_date).toISOString().split('T')[0] : '' %>" />
            </div>
          </div>
        </div>

        <div class="flex gap-3 justify-end">
          <a href="/committees/<%= committee.id %>/tasks" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="btn-ghost text-zinc-900 dark:text-zinc-100">Batal</a>
          <button type="submit" class="btn" id="save-edit-task-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Simpan Perubahan
          </button>
        </div>

      </form>
    </div>
  </div>

</main>
<%- include('../partials/_scripts') %>
</body>
</html>
