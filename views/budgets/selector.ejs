<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">
<%- include('../partials/_sidebar', { user }) %>
<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="flex flex-1 items-center gap-2 text-sm text-muted-foreground">
      <span class="text-foreground font-medium">Kelola RAB</span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></span>
        <span class="block dark:hidden"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg></span>
      </button>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-8 bg-muted/20 min-h-[calc(100vh-3.5rem)]">
    <div class="max-w-screen-xl mx-auto">

      <div class="mb-6">
        <h2 class="text-xl font-bold tracking-tight">Kelola RAB</h2>
        <p class="text-sm text-muted-foreground mt-1">Pilih kepanitiaan untuk melihat atau mengelola Rencana Anggaran Biaya.</p>
      </div>

      <% if (committees.length === 0) { %>
      <div class="card p-12 text-center">
        <div class="size-16 rounded-full bg-muted flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <p class="font-semibold text-base">Belum ada kepanitiaan</p>
        <p class="text-sm text-muted-foreground mt-1 mb-4">Buat kepanitiaan terlebih dahulu sebelum mengelola RAB.</p>
        <a href="/committees" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="btn btn-sm">Kelola Kepanitiaan</a>
      </div>
      <% } else { %>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        <% committees.forEach(committee => { %>
        <div class="card p-4 flex flex-col gap-3 hover:shadow-md transition-shadow">
          <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sm leading-snug truncate"><%= committee.name %></p>
              <p class="text-xs text-muted-foreground mt-0.5"><%= committee.budget_count %> RAB</p>
            </div>
          </div>
          <a
            href="/committees/<%= committee.id %>/budgets"
            hx-boost="true"
            hx-select="#content"
            hx-target="#content"
            hx-swap="outerHTML"
            class="btn btn-sm w-full justify-center gap-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            Buka RAB
          </a>
        </div>
        <% }) %>
      </div>

      <% } %>
    </div>
  </div>

</main>
<%- include('../partials/_scripts') %>
</body>
</html>
