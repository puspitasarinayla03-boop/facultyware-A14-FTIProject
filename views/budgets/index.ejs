<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">
<%- include('../partials/_sidebar', { user }) %>
<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="flex flex-1 items-center gap-2 text-sm text-muted-foreground">
      <a href="/committees" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="hover:text-foreground transition-colors">Kepanitiaan</a>
      <span>/</span>
      <a href="/committees/<%= committee.id %>" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="hover:text-foreground transition-colors truncate max-w-[180px]"><%= committee.name %></a>
      <span>/</span>
      <span class="text-foreground font-medium">RAB</span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></span>
        <span class="block dark:hidden"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg></span>
      </button>
      <a href="/committees/<%= committee.id %>/budgets/create" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="btn btn-sm gap-1.5" id="add-budget-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        Tambah RAB
      </a>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-8 bg-muted/20 min-h-[calc(100vh-3.5rem)]">
    <div class="max-w-screen-xl mx-auto">

      <div class="mb-6">
        <h2 class="text-xl font-bold tracking-tight">Rencana Anggaran Biaya (RAB)</h2>
        <p class="text-sm text-muted-foreground mt-1">Kepanitiaan: <strong><%= committee.name %></strong></p>
      </div>

      <% if (budgets.length === 0) { %>
      <div class="card p-12 text-center">
        <div class="size-16 rounded-full bg-muted flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
            <path d="M2 17a5 5 0 0 0 10 0c0-2.76-2.5-5-5-3-2.5-2-5 .24-5 3z"/><path d="M12 17a5 5 0 0 0 10 0c0-2.76-2.5-5-5-3-2.5-2-5 .24-5 3z"/><path d="M7 14c3.22-2.91 4.29-8.75 5-12 1.66 2.38 4.94 9 5 12"/>
          </svg>
        </div>
        <p class="font-semibold text-base">Belum ada RAB</p>
        <p class="text-sm text-muted-foreground mt-1 mb-4">Buat rencana anggaran biaya untuk kepanitiaan ini.</p>
        <a href="/committees/<%= committee.id %>/budgets/create" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="btn btn-sm">Buat RAB Pertama</a>
      </div>
      <% } else { %>

      <div class="grid gap-4">
        <% budgets.forEach(b => {
          const total    = parseFloat(b.total_amount)  || 0;
          const used     = parseFloat(b.used_amount)   || 0;
          const pct      = total > 0 ? Math.min(100, Math.round((used / total) * 100)) : 0;
          const barColor = pct >= 90 ? 'bg-destructive' : pct >= 70 ? 'bg-amber-500' : 'bg-primary';
          const fmt = (n) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(n);
        %>
        <div class="card p-5">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
            <div>
              <h3 class="font-semibold text-base"><%= b.name %></h3>
              <% if (b.description) { %><p class="text-sm text-muted-foreground mt-0.5"><%= b.description %></p><% } %>
              <p class="text-xs text-muted-foreground mt-1"><%= b.item_count %> item anggaran</p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a href="/committees/<%= committee.id %>/budgets/<%= b.id %>/export-excel" hx-boost="false"
                 class="btn-outline btn-sm gap-1.5 text-green-700 border-green-300 hover:bg-green-50 dark:text-green-400 dark:border-green-700 dark:hover:bg-green-900/20" id="export-rab-<%= b.id %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Excel
              </a>
              <a href="/committees/<%= committee.id %>/budgets/<%= b.id %>" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML" class="btn btn-sm">Detail</a>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4 mb-4">
            <div class="text-center p-3 rounded-lg bg-muted/40">
              <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Total Anggaran</p>
              <p class="font-bold text-sm"><%= fmt(total) %></p>
            </div>
            <div class="text-center p-3 rounded-lg bg-muted/40">
              <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Realisasi</p>
              <p class="font-bold text-sm text-amber-600 dark:text-amber-400"><%= fmt(used) %></p>
            </div>
            <div class="text-center p-3 rounded-lg bg-muted/40">
              <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Sisa</p>
              <p class="font-bold text-sm text-green-600 dark:text-green-400"><%= fmt(total - used) %></p>
            </div>
          </div>

          <div class="w-full bg-muted rounded-full h-2">
            <div class="<%= barColor %> h-2 rounded-full transition-all duration-500" style="width:<%= pct %>%"></div>
          </div>
          <p class="text-xs text-muted-foreground mt-1.5 text-right"><%= pct %>% terpakai</p>
        </div>
        <% }) %>
      </div>

      <% } %>
    </div>
  </div>

</main>
<%- include('../partials/_scripts') %>
</body>
</html>
