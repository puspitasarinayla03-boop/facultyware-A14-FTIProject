<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title: 'Detail Progress' }) %>
<body class="bg-background text-foreground antialiased">
<%- include('../partials/_sidebar', { user: user }) %>
<main id="content">
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/progresses" class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Semua Progress
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold truncate flex-1">Detail Progress Project</h1>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
    </div>
  </header>

  <div class="p-4 md:p-6 lg:p-8">
    <div class="max-w-3xl mx-auto space-y-6">

      <div class="card p-6">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
          <div class="flex-1 space-y-2">
            <div class="flex items-center gap-2">
              <h2 class="text-xl font-bold"><%= progress.task_title || '—' %></h2>
              <% if (progress.status === 'done') { %>
                <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400">Selesai</span>
              <% } else { %>
                <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">Sedang Berlangsung</span>
              <% } %>
            </div>
            <p class="text-muted-foreground text-sm"><%= progress.committee_name || '—' %></p>
          </div>

          <!-- Action Buttons: Edit, Export DOCX, Hapus -->
          <div class="flex gap-2 flex-wrap">
            <a href="/progresses/<%= progress.id %>/edit" class="btn btn-sm gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
              </svg>
              Edit
            </a>
            <a href="/progresses/<%= progress.id %>/export-docx" class="btn-outline btn-sm gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>
              </svg>
              Export DOCX
            </a>
            <button type="button" onclick="showDeleteModal()" class="btn-outline btn-sm text-destructive hover:bg-destructive/10 gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
              </svg>
              Hapus
            </button>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card p-4">
          <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">Tanggal Progress</div>
          <div class="text-base font-medium">
            <% if (progress.progress_date) { %>
              <%= new Date(progress.progress_date).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
            <% } else { %>
              —
            <% } %>
          </div>
        </div>
        <div class="card p-4">
          <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">Status</div>
          <div class="text-base font-medium capitalize">
            <%= (progress.status === 'in_progress') ? 'Sedang Berlangsung' : 'Selesai' %>
          </div>
        </div>
      </div>

      <div class="card p-6 space-y-3">
        <h3 class="font-semibold text-sm">Deskripsi Progress</h3>
        <div class="text-foreground text-sm leading-relaxed whitespace-pre-wrap">
          <%= progress.description || '—' %>
        </div>
      </div>

      <% if (progress.attachment) { %>
        <div class="card p-6 space-y-3">
          <h3 class="font-semibold text-sm">File Attachment</h3>
          <div class="flex items-center gap-3 p-4 rounded-lg bg-muted/50">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground flex-shrink-0">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium truncate"><%= progress.attachment.split('/').pop() %></p>
              <p class="text-xs text-muted-foreground">Klik tombol untuk download</p>
            </div>
            <a href="<%= progress.attachment %>" download class="btn-sm btn-outline flex-shrink-0">Download</a>
          </div>
        </div>
      <% } else { %>
        <%# [A2] Tidak ada attachment — sesuai Flow 2 Alternative A2 %>
        <div class="card p-6 space-y-3">
          <h3 class="font-semibold text-sm">File Attachment</h3>
          <div class="flex items-center gap-3 p-4 rounded-lg bg-muted/50">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground flex-shrink-0">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            <p class="text-sm text-muted-foreground">Tidak ada attachment.</p>
          </div>
        </div>
      <% } %>

      <div class="card p-4">
        <div class="grid grid-cols-2 gap-4 text-xs text-muted-foreground">
          <div>
            <span class="font-semibold block mb-1">ID Progress</span>
            <code class="text-xs bg-muted/50 px-2 py-1 rounded"><%= progress.id %></code>
          </div>
          <div>
            <span class="font-semibold block mb-1">Terakhir Diubah</span>
            <% if (progress.updated_at) { %>
              <%= new Date(progress.updated_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }) %>
            <% } else { %>
              —
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>

  <%# ── Delete Confirmation Modal ── %>
  <div id="deleteModal" style="display: none;" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-background rounded-lg shadow-lg max-w-sm w-full p-6 space-y-4">
      <div class="flex items-center gap-3">
        <div class="size-10 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive">
            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <div>
          <h3 class="font-semibold">Hapus Progress?</h3>
          <p class="text-sm text-muted-foreground mt-0.5">Tindakan ini tidak dapat dibatalkan.</p>
        </div>
      </div>
      <div class="flex gap-2 justify-end pt-2">
        <button type="button" onclick="closeDeleteModal()" class="btn-outline btn-sm">Batal</button>
        <form method="POST" action="/progresses/<%= progress.id %>/delete" style="display: inline;">
          <button type="submit" class="btn-destructive btn-sm">Hapus Progress</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    function showDeleteModal() { document.getElementById('deleteModal').style.display = 'flex'; }
    function closeDeleteModal() { document.getElementById('deleteModal').style.display = 'none'; }
    // Clean up event listener when content swaps if necessary, but standard keydown is fine
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDeleteModal(); });
  </script>
</main>

<%- include('../partials/_scripts') %>
</body>
</html>