<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title: 'Detail Progress' }) %>
<body class="bg-background text-foreground antialiased">
<%- include('../partials/_sidebar', { user: user }) %>
<main id="content">
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/progresses" class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Semua Progress
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold truncate flex-1">Detail Progress Project</h1>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
    </div>
  </header>

  <%
    const statusMap = {
      done:        'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400',
      in_progress: 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300',
    };
    const statusLabels = {
      done:        'Selesai',
      in_progress: 'Sedang Berlangsung',
    };
    const statusClass = statusMap[progress.status] || 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300';
    const statusLabel = statusLabels[progress.status] || progress.status;
  %>

  <div class="p-4 md:p-6 lg:p-8">
    <div class="max-w-3xl mx-auto space-y-6">

      <div class="card">
        <section class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
          <div class="flex-1 space-y-2">
            <div class="flex items-center gap-2 flex-wrap">
              <h2 class="text-xl font-bold"><%= progress.task_title || '—' %></h2>
              <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium <%= statusClass %>">
                <%= statusLabel %>
              </span>
            </div>
            <p class="text-muted-foreground text-sm"><%= progress.committee_name || '—' %></p>
          </div>

          <div class="flex gap-2 flex-wrap shrink-0">
            <a href="/progresses/<%= progress.id %>/edit" class="btn btn-sm gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
              </svg>
              Edit
            </a>
            <a href="/progresses/<%= progress.id %>/export-docx" class="btn-outline btn-sm gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>
              </svg>
              Export DOCX
            </a>
            <form method="POST" action="/progresses/<%= progress.id %>/delete" class="inline-block m-0">
              <button type="button" onclick="showDeleteModal(this.closest('form'))"
                      class="btn-outline btn-sm text-destructive hover:bg-destructive/10 hover:border-destructive/40 gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                </svg>
                Hapus
              </button>
            </form>
          </div>
        </section>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card">
          <header>
            <h3 class="font-semibold">Tanggal Progress</h3>
          </header>
          <section>
            <p class="text-sm font-medium">
              <% if (progress.progress_date) { %>
                <%= new Date(progress.progress_date).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
              <% } else { %>
                —
              <% } %>
            </p>
          </section>
        </div>
        <div class="card">
          <header>
            <h3 class="font-semibold">Status</h3>
          </header>
          <section>
            <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium <%= statusClass %>">
              <%= statusLabel %>
            </span>
          </section>
        </div>
      </div>

      <div class="card">
        <header>
          <h3 class="font-semibold">Deskripsi Progress</h3>
        </header>
        <section>
          <p class="text-sm text-muted-foreground leading-relaxed whitespace-pre-wrap"><%= progress.description || '—' %></p>
        </section>
      </div>

      <% if (progress.attachment) { %>
        <div class="card">
          <header>
            <h3 class="font-semibold">File Attachment</h3>
          </header>
          <section>
            <div class="flex items-center gap-3 p-4 rounded-lg bg-muted/50">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground flex-shrink-0">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
              </svg>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium truncate"><%= progress.attachment.split('/').pop() %></p>
                <p class="text-xs text-muted-foreground">Klik tombol untuk download</p>
              </div>
              <a href="<%= progress.attachment %>" download class="btn-outline btn-sm flex-shrink-0">Download</a>
            </div>
          </section>
        </div>
      <% } else { %>
        <div class="card">
          <header>
            <h3 class="font-semibold">File Attachment</h3>
          </header>
          <section>
            <div class="flex items-center gap-3 p-4 rounded-lg bg-muted/50">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground flex-shrink-0">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
              </svg>
              <p class="text-sm text-muted-foreground">Tidak ada attachment.</p>
            </div>
          </section>
        </div>
      <% } %>

      <div class="card">
        <section class="grid grid-cols-2 gap-4 text-xs text-muted-foreground">
          <div>
            <span class="font-semibold block mb-1">ID Progress</span>
            <code class="text-xs bg-muted/50 px-2 py-1 rounded"><%= progress.id %></code>
          </div>
          <div>
            <span class="font-semibold block mb-1">Terakhir Diubah</span>
            <% if (progress.updated_at) { %>
              <%= new Date(progress.updated_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }) %>
            <% } else { %>
              —
            <% } %>
          </div>
        </section>
      </div>

    </div>
  </div>

  <%# ── Delete Confirmation Modal (Basecoat dialog) ── %>
  <dialog id="delete-modal" class="dialog">
    <div class="dialog-content max-w-sm">
      <header class="dialog-header">
        <h2 class="dialog-title">Hapus Progress?</h2>
        <p class="dialog-description">Tindakan ini tidak dapat dibatalkan. Data progress akan dihapus permanen.</p>
      </header>
      <footer class="dialog-footer">
        <button type="button" class="btn-outline" onclick="document.getElementById('delete-modal').close()">Batal</button>
        <button type="button" id="confirm-delete-btn" class="btn bg-destructive text-white hover:bg-destructive/90">Hapus</button>
      </footer>
    </div>
  </dialog>

  <script>
    let _deleteForm = null;
    function showDeleteModal(form) {
      _deleteForm = form;
      document.getElementById('delete-modal').showModal();
    }
    document.getElementById('confirm-delete-btn').addEventListener('click', () => {
      if (_deleteForm) _deleteForm.submit();
    });
  </script>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>