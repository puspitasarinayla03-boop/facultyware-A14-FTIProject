<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title: 'Edit Progress' }) %>
<body class="bg-background text-foreground antialiased">
<%- include('../partials/_sidebar', { user: user }) %>
<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/progresses/<%= progress.id %>"
       class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Kembali
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold">Edit Progress Project</h1>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-md mx-auto">

      <%# Error Alert %>
      <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="mb-6 rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive">
        <p class="font-medium mb-1">Terdapat kesalahan pada input:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% errors.forEach(function(err) { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form method="POST" action="/progresses/<%= progress.id %>/update" enctype="multipart/form-data" class="grid gap-6">

        <%# ── Informasi Task ── %>
        <div class="card">
          <header>
            <h2>Informasi Progress</h2>
            <p>Ubah task dan detail perkembangan yang sudah dilakukan.</p>
          </header>

          <section class="grid gap-5">
            <div class="grid gap-2">
              <label for="committee_task_id">Task Project <span class="text-destructive">*</span></label>
              <select id="committee_task_id" name="committee_task_id" required class="select w-full">
                <option value="">-- Pilih Task --</option>
                <% if (typeof tasks !== 'undefined') { %>
                  <% tasks.forEach(function(task) { %>
                    <option value="<%= task.id %>" <%= (progress.committee_task_id == task.id) ? 'selected' : '' %>><%= task.committee_name %> — <%= task.title %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div class="grid gap-2">
              <label for="description">Deskripsi Progress <span class="text-destructive">*</span></label>
              <textarea id="description" name="description" rows="4" required
                        placeholder="Jelaskan perkembangan yang sudah dilakukan..."
                        class="input w-full min-h-[100px] py-2 resize-y"><%= progress.description || '' %></textarea>
            </div>
          </section>
        </div>

        <%# ── Status & Tanggal ── %>
        <div class="card">
          <header>
            <h2>Status & Jadwal</h2>
          </header>

          <section class="grid gap-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="status">Status <span class="text-destructive">*</span></label>
                <select id="status" name="status" required class="select w-full">
                  <option value="">-- Pilih Status --</option>
                  <option value="in_progress" <%= (progress.status === 'in_progress') ? 'selected' : '' %>>Sedang Berlangsung</option>
                  <option value="done"        <%= (progress.status === 'done')        ? 'selected' : '' %>>Selesai</option>
                </select>
              </div>

              <div class="grid gap-2">
                <label for="progress_date">Tanggal Progress <span class="text-destructive">*</span></label>
                <input type="date" id="progress_date" name="progress_date" required
                       value="<%= progress.progress_date ? new Date(progress.progress_date).toISOString().split('T')[0] : '' %>"
                       class="input w-full"/>
              </div>
            </div>
          </section>
        </div>

        <%# ── Attachment ── %>
        <div class="card">
          <header>
            <h2>File Attachment</h2>
            <p>Opsional. Maks 5MB — JPG, PNG, atau PDF.</p>
          </header>
          <section class="grid gap-4">
            <% if (progress.attachment) { %>
              <div class="flex items-center gap-3 p-3 rounded-lg bg-muted/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                </svg>
                <span class="text-sm text-muted-foreground flex-1 truncate">File saat ini: <strong><%= progress.attachment.split('/').pop() %></strong></span>
                <a href="<%= progress.attachment %>" download class="btn-outline btn-sm">Download</a>
              </div>
              <p class="text-xs text-muted-foreground -mt-2">Upload file baru untuk mengganti file yang ada:</p>
            <% } %>
            <div class="grid gap-2">
              <label for="attachment">Upload File</label>
              <input type="file" id="attachment" name="attachment"
                     accept=".jpg,.jpeg,.png,.pdf"
                     class="input w-full file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-muted file:text-foreground hover:file:bg-muted/80 cursor-pointer"/>
            </div>
          </section>
        </div>

        <%# ── Actions ── %>
        <div class="flex items-center justify-end gap-3 pt-2">
          <a href="/progresses/<%= progress.id %>" class="btn-outline">Batal</a>
          <button type="submit" class="btn">Simpan Perubahan</button>
        </div>

      </form>
    </div>
  </div>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>