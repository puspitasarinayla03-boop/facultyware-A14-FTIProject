<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title: typeof title !== 'undefined' ? title : 'Tambah Progress' }) %>
<body class="bg-background text-foreground antialiased">

<%- include('../partials/_sidebar', { user: typeof user !== 'undefined' ? user : '' }) %>

<main id="content">

  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <a href="/progresses"
       class="btn-sm-ghost h-7 text-muted-foreground gap-1.5 hidden sm:inline-flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Kembali
    </a>
    <span class="text-muted-foreground hidden sm:inline">/</span>
    <h1 class="text-base font-semibold">Tambah Progress Project</h1>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" aria-label="Toggle dark mode"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
    </div>
  </header>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-md mx-auto">

      <%# Error Alert %>
      <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="mb-6 rounded-lg border border-destructive/40 bg-destructive/10 px-4 py-3 text-sm text-destructive">
        <p class="font-medium mb-1">Terdapat kesalahan pada input:</p>
        <ul class="list-disc list-inside space-y-0.5">
          <% errors.forEach(function(err) { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form method="POST" action="/progresses" enctype="multipart/form-data" class="grid gap-6">

        <%# ── Informasi Kegiatan & Task ── %>
        <div class="card">
          <header>
            <h2>Informasi Kegiatan & Task</h2>
            <p>Pilih jenis kegiatan, nama kegiatan, dan task yang sesuai.</p>
          </header>

          <section class="grid gap-5">
            <%# 1. Pilih Jenis Kegiatan %>
            <div class="grid gap-2">
              <label for="activity_type">Jenis Kegiatan <span class="text-destructive">*</span></label>
              <select id="activity_type" name="activity_type" required class="select w-full"
                      hx-get="/progresses/api/activities"
                      hx-target="#activity_id"
                      hx-trigger="change"
                      hx-swap="innerHTML">
                <option value="project" <%= (typeof old !== 'undefined' && old.activity_type === 'project') ? 'selected' : '' %>>Project</option>
                <option value="kepanitiaan" <%= (typeof old !== 'undefined' && old.activity_type === 'kepanitiaan') ? 'selected' : '' %>>Kepanitiaan</option>
              </select>
            </div>

            <%# 2. Pilih Kegiatan %>
            <div class="grid gap-2">
              <label for="activity_id">Nama Kegiatan <span class="text-destructive">*</span></label>
              <select id="activity_id" name="activity_id" required class="select w-full"
                      hx-get="/progresses/api/tasks"
                      hx-target="#committee_task_id"
                      hx-trigger="change"
                      hx-swap="innerHTML">
                <option value="">-- Pilih Kegiatan --</option>
                <% if (typeof activities !== 'undefined') { %>
                  <% activities.forEach(function(act) { %>
                    <option value="<%= act.id %>" <%= (typeof old !== 'undefined' && old.activity_id == act.id) ? 'selected' : '' %>>
                      <%= act.name %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <%# 3. Pilih Task %>
            <div class="grid gap-2">
              <label for="committee_task_id">Task Kegiatan <span class="text-destructive">*</span></label>
              <select id="committee_task_id" name="committee_task_id" required class="select w-full"
                      hx-get="/progresses/api/new-task-fields"
                      hx-target="#new_task_fields_container"
                      hx-trigger="change"
                      hx-include="#activity_type,#activity_id"
                      hx-swap="innerHTML">
                <option value="">-- Pilih Task --</option>
                <% if (typeof tasks !== 'undefined' && tasks.length > 0) { %>
                  <% tasks.forEach(function(task) { %>
                    <option value="<%= task.id %>" <%= (typeof old !== 'undefined' && old.committee_task_id == task.id) ? 'selected' : '' %>>
                      <%= task.title %>
                    </option>
                  <% }) %>
                <% } %>
                <% if (typeof old !== 'undefined' && old.activity_id) { %>
                  <option value="new" <%= (typeof old !== 'undefined' && old.committee_task_id === 'new') ? 'selected' : '' %>>[ + Tambah Task Baru ]</option>
                <% } %>
              </select>
            </div>

            <%# Container untuk Input Task Baru (Dinamis via HTMX) %>
            <div id="new_task_fields_container">
              <% if (typeof old !== 'undefined' && old.committee_task_id === 'new') { %>
                <div class="grid gap-4 p-4 border rounded-lg bg-muted/30">
                  <div class="grid gap-2">
                    <label for="new_task_title" class="font-medium text-sm">Judul Task Baru <span class="text-destructive">*</span></label>
                    <input type="text" id="new_task_title" name="new_task_title" required
                           value="<%= old.new_task_title || '' %>"
                           placeholder="Contoh: Desain Database, Integrasi API..."
                           class="input w-full"/>
                  </div>

                  <% if (old.activity_type === 'kepanitiaan') { %>
                    <div class="grid gap-2">
                      <label for="new_task_member_id" class="font-medium text-sm">Penanggung Jawab <span class="text-destructive">*</span></label>
                      <select id="new_task_member_id" name="new_task_member_id" required class="select w-full">
                        <option value="">-- Pilih Penanggung Jawab --</option>
                        <% if (typeof members !== 'undefined') { %>
                          <% members.forEach(function(member) { %>
                            <option value="<%= member.id %>" <%= (old.new_task_member_id == member.id) ? 'selected' : '' %>>
                              <%= member.name %> (<%= member.role %>)
                            </option>
                          <% }) %>
                        <% } %>
                      </select>
                    </div>
                  <% } %>
                </div>
              <% } %>
            </div>

            <div class="grid gap-2">
              <label for="description">Deskripsi Progress <span class="text-destructive">*</span></label>
              <textarea id="description" name="description" rows="4" required
                        placeholder="Jelaskan perkembangan yang sudah dilakukan..."
                        class="input w-full min-h-[100px] py-2 resize-y"><%= (typeof old !== 'undefined' && old.description) ? old.description : '' %></textarea>
            </div>
          </section>
        </div>

        <%# ── Status & Tanggal ── %>
        <div class="card">
          <header>
            <h2>Status & Jadwal</h2>
          </header>

          <section class="grid gap-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="grid gap-2">
                <label for="status">Status <span class="text-destructive">*</span></label>
                <select id="status" name="status" required class="select w-full">
                  <option value="">-- Pilih Status --</option>
                  <option value="in_progress"
                    <%= (typeof old !== 'undefined' && old.status === 'in_progress') ? 'selected' : '' %>>
                    Sedang Berlangsung
                  </option>
                  <option value="done"
                    <%= (typeof old !== 'undefined' && old.status === 'done') ? 'selected' : '' %>>
                    Selesai
                  </option>
                </select>
              </div>

              <div class="grid gap-2">
                <label for="progress_date">Tanggal Progress <span class="text-destructive">*</span></label>
                <input type="date" id="progress_date" name="progress_date" required
                       value="<%= (typeof old !== 'undefined' && old.progress_date) ? old.progress_date : new Date().toISOString().split('T')[0] %>"
                       class="input w-full"/>
              </div>
            </div>
          </section>
        </div>

        <%# ── Attachment ── %>
        <div class="card">
          <header>
            <h2>File Attachment</h2>
            <p>Opsional. Maks 5MB — JPG, PNG, atau PDF.</p>
          </header>
          <section>
            <div class="grid gap-2">
              <label for="attachment">Upload File</label>
              <input type="file" id="attachment" name="attachment"
                     accept=".jpg,.jpeg,.png,.pdf"
                     class="input w-full file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-muted file:text-foreground hover:file:bg-muted/80 cursor-pointer"/>
            </div>
          </section>
        </div>

        <%# ── Actions ── %>
        <div class="flex items-center justify-end gap-3 pt-2">
          <a href="/progresses" class="btn-outline">Batal</a>
          <button type="submit" class="btn">Simpan Progress</button>
        </div>

      </form>
    </div>
  </div>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>