<!doctype html>
<html lang="id">
<%- include('../partials/_head', { title: 'Progress Project' }) %>
<body class="bg-background text-foreground antialiased" hx-boost="true">

<%- include('../partials/_sidebar', { user: user }) %>

<main id="content">
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 px-4 h-14">
    <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" class="btn-sm-icon-ghost md:hidden mr-2 size-7 -ml-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="flex flex-1 items-center gap-4">
      <h1 class="text-base font-semibold">Progress &amp; Aktivitas</h1>
      <span class="text-muted-foreground text-sm hidden sm:inline">(<%= progresses.length %> data)</span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <a href="/progresses/create" class="btn btn-sm gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14"/><path d="M5 12h14"/>
        </svg>
        Tambah Progress
      </a>
      <button type="button" aria-label="Toggle dark mode" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8 flex items-center justify-center shrink-0">
        <span class="hidden dark:block">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </span>
        <span class="block dark:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </span>
      </button>
    </div>
  </header>

  <div class="p-4 md:p-6 lg:p-8">
    <div class="max-w-screen-xl mx-auto space-y-6">

      <%# ── Akses Cepat: Task, Expenses & RAB ── %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

        <a href="/tasks"
           hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
           class="card p-4 flex items-center gap-4 hover:bg-accent transition-colors group">
          <div class="flex items-center justify-center size-10 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-600 dark:text-violet-400 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-sm">Kelola Task</p>
            <p class="text-xs text-muted-foreground">Lihat & kelola task per kepanitiaan</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>

        <a href="/expenses"
           hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
           class="card p-4 flex items-center gap-4 hover:bg-accent transition-colors group">
          <div class="flex items-center justify-center size-10 rounded-full bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-sm">Kelola Expenses</p>
            <p class="text-xs text-muted-foreground">Input & pantau pengeluaran per kepanitiaan</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>

        <a href="/budgets"
           hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML"
           class="card p-4 flex items-center gap-4 hover:bg-accent transition-colors group">
          <div class="flex items-center justify-center size-10 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-sm">Kelola RAB</p>
            <p class="text-xs text-muted-foreground">Rencana anggaran & realisasi per kepanitiaan</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground shrink-0">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>

      </div>

      <div class="card overflow-hidden">

        <% if (!progresses || progresses.length === 0) { %>

          <div class="flex flex-col items-center justify-center py-24 text-center gap-4">
            <div class="size-16 rounded-full bg-muted flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
                <path d="M3 3v18h18"/><path d="M7 14l3-3 2 2 5-5"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-sm">Belum ada progress project</p>
              <p class="text-muted-foreground text-xs mt-1">Progress task akan muncul di sini setelah ditambahkan.</p>
              <a href="/progresses/create" class="btn btn-sm gap-1 mt-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5v14"/><path d="M5 12h14"/>
                </svg>
                Tambah Progress Pertama
              </a>
            </div>
          </div>

        <% } else { %>

          <div class="overflow-x-auto w-full">
            <table class="w-full text-sm">
              <thead class="bg-muted/40 border-b">
                <tr>
                  <th class="text-center px-4 py-3 font-medium text-muted-foreground w-10">#</th>
                  <th class="text-left px-4 py-3 font-medium text-muted-foreground">Committee</th>
                  <th class="text-left px-4 py-3 font-medium text-muted-foreground">Task</th>
                  <th class="text-left px-4 py-3 font-medium text-muted-foreground hidden lg:table-cell">Deskripsi Progress</th>
                  <th class="text-center px-4 py-3 font-medium text-muted-foreground hidden sm:table-cell">Tanggal</th>
                  <th class="text-center px-4 py-3 font-medium text-muted-foreground">Status</th>
                  <th class="text-center px-4 py-3 font-medium text-muted-foreground">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y">

                <% progresses.forEach(function(progress, i) {
                  const statusMap = {
                    done:        'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400',
                    in_progress: 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300',
                  };
                  const statusLabels = {
                    done:        'Selesai',
                    in_progress: 'Sedang Berlangsung',
                  };
                  const statusClass = statusMap[progress.status] || 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300';
                  const statusLabel = statusLabels[progress.status] || progress.status;
                %>
                <tr class="hover:bg-muted/30 transition-colors">
                  <td class="px-4 py-3 text-muted-foreground text-xs text-center"><%= i + 1 %></td>
                  <td class="px-4 py-3"><span class="font-medium block truncate max-w-[160px]"><%= progress.committee_name || '—' %></span></td>
                  <td class="px-4 py-3"><span class="block truncate max-w-[180px]"><%= progress.task_title || '—' %></span></td>
                  <td class="px-4 py-3 text-muted-foreground text-xs hidden lg:table-cell"><span class="block truncate max-w-[260px]"><%= progress.description || '—' %></span></td>
                  <td class="px-4 py-3 text-xs text-muted-foreground whitespace-nowrap text-center hidden sm:table-cell">
                    <% if (progress.progress_date) { %>
                      <%= new Date(progress.progress_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    <% } else { %>
                      —
                    <% } %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= statusClass %>">
                      <%= statusLabel %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <div class="flex items-center justify-center gap-1">
                      <a href="/progresses/<%= progress.id %>" class="btn-sm-icon-ghost size-7" title="Lihat Detail">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                      </a>
                      <a href="/progresses/<%= progress.id %>/edit" class="btn-sm-icon-ghost size-7 text-blue-600 hover:text-blue-700 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/30" title="Edit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/>
                        </svg>
                      </a>
                      <button type="button" onclick="triggerDownload('/progresses/<%= progress.id %>/export-docx', 'progress_<%= progress.id %>.docx')" class="btn-sm-icon-ghost size-7 text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50 dark:text-emerald-400 dark:hover:bg-emerald-900/30" title="Ekspor DOCX">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>
                        </svg>
                      </button>
                      <form method="POST" action="/progresses/<%= progress.id %>/delete" class="inline-block m-0">
                        <button type="button" onclick="showDeleteModal(this.closest('form'))"
                                class="btn-sm-icon-ghost size-7 text-destructive hover:bg-destructive/10" title="Hapus">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>

              </tbody>
            </table>
          </div>

        <% } %>

      </div>
    </div>
  </div>

  <%# ── Delete Confirmation Modal (Basecoat dialog) ── %>
  <dialog id="delete-modal" class="dialog">
    <div class="dialog-content max-w-sm">
      <header class="dialog-header">
        <h2 class="dialog-title">Hapus Progress?</h2>
        <p class="dialog-description">Tindakan ini tidak dapat dibatalkan. Data progress akan dihapus permanen.</p>
      </header>
      <footer class="dialog-footer">
        <button type="button" class="btn-outline" onclick="document.getElementById('delete-modal').close()">Batal</button>
        <button type="button" id="confirm-delete-btn" class="btn bg-destructive text-white hover:bg-destructive/90">Hapus</button>
      </footer>
    </div>
  </dialog>

  <script>
    var _deleteForm = null;
    function showDeleteModal(form) {
      _deleteForm = form;
      document.getElementById('delete-modal').showModal();
    }
    document.getElementById('confirm-delete-btn').addEventListener('click', () => {
      if (_deleteForm) _deleteForm.submit();
    });
  </script>

</main>

<%- include('../partials/_scripts') %>
</body>
</html>